# ── Contact Form ──────────────────────────────────────────────────────────────
#
# 1. Google reCAPTCHA v2 site key
#    Register at: https://www.google.com/recaptcha/admin
#    Select "reCAPTCHA v2 → I'm not a robot Checkbox"
#    Add your domain (kairos.capital) and localhost for testing
#
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_v2_site_key_here

# 2. Web3Forms access key  (free — 250 submissions/month)
#    Register at: https://web3forms.com
#    Enter hello@kairos.capital as the email to receive form submissions
#    Copy the access key shown on the dashboard
#
NEXT_PUBLIC_WEB3FORMS_KEY=your_web3forms_access_key_here

# ── Cloudflare Pages ───────────────────────────────────────────────────────────
# Set these in the Cloudflare Pages dashboard → Settings → Environment Variables
# (also add TINA_TOKEN and NEXT_PUBLIC_TINA_CLIENT_ID if using Tina Cloud)
#
NEXT_PUBLIC_SITE_URL=https://kairos.capital
